<Window x:Class="KATTHEDEV.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mod Manager" 
        Height="780" Width="1150" 
        MinWidth="1150" MinHeight="700" 
        ResizeMode="CanResize"
        Background="#121212"
        WindowStartupLocation="CenterScreen" 
        Icon="Image/logo.ico"
        FontFamily="Inter">
    <Window.Resources>
        <Storyboard x:Key="SpinAnimation" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                         From="0" To="360" Duration="0:0:1.2"/>
        </Storyboard>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="tabBorder" BorderThickness="0,0,0,3" Padding="25,10" Margin="5,0" Cursor="Hand" Background="Transparent">
                            <ContentPresenter x:Name="ContentSite" ContentSource="Header" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="tabBorder" Property="Border.BorderBrush" Value="#673AB7"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter TargetName="tabBorder" Property="Border.BorderBrush" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#666"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmartButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Content" Value="ACTIVATE">
                    <Setter Property="Background" Value="#673AB7"/>
                </Trigger>
                <Trigger Property="Content" Value="KÍCH HOẠT">
                    <Setter Property="Background" Value="#673AB7"/>
                </Trigger>
                <Trigger Property="Content" Value="激活">
                    <Setter Property="Background" Value="#673AB7"/>
                </Trigger>
                <Trigger Property="Content" Value="INSTALLED">
                    <Setter Property="Background" Value="#2E7D32"/>
                </Trigger>
                <Trigger Property="Content" Value="ĐÃ CÀI ĐẶT">
                    <Setter Property="Background" Value="#2E7D32"/>
                </Trigger>
                <Trigger Property="Content" Value="已安装">
                    <Setter Property="Background" Value="#2E7D32"/>
                </Trigger>
                <Trigger Property="Content" Value="UPDATE">
                    <Setter Property="Background" Value="#C2185B"/>
                </Trigger>
                <Trigger Property="Content" Value="CẬP NHẬT">
                    <Setter Property="Background" Value="#C2185B"/>
                </Trigger>
                <Trigger Property="Content" Value="更新">
                    <Setter Property="Background" Value="#C2185B"/>
                </Trigger>
                <Trigger Property="Content" Value="DOWNLOADING...">
                    <Setter Property="Background" Value="#FF9800"/>
                </Trigger>
                <Trigger Property="Content" Value="ĐANG TẢI...">
                    <Setter Property="Background" Value="#FF9800"/>
                </Trigger>
                <Trigger Property="Content" Value="下载中...">
                    <Setter Property="Background" Value="#FF9800"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid x:Name="MainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1E1E1E" BorderBrush="#333" BorderThickness="0,0,0,1" Padding="20,15">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Mod Manager" Foreground="White" FontSize="26" FontWeight="Bold" Margin="8,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                    <Border Background="#121212" CornerRadius="15" Padding="12,0" Width="220" Margin="0,0,15,0" BorderBrush="#333" BorderThickness="1">
                        <Grid>
                            <TextBlock x:Name="lblSearchPlaceholder" Text="🔍 Search mods..." Foreground="#AAA" VerticalAlignment="Center" Margin="10,0,0,0" Visibility="{Binding Text.IsEmpty, ElementName=txtSearch, Converter={StaticResource BoolToVis}}"/>

                            <TextBox x:Name="txtSearch" CaretBrush="White" Background="Transparent" Foreground="White" BorderThickness="0" VerticalContentAlignment="Center" TextChanged="txtSearch_TextChanged"/>
                        </Grid>
                    </Border>
                    <Button x:Name="btnUpdateAll" Content="UPDATE ALL" Click="btnUpdateAll_Click" Background="#C2185B" Foreground="White" Padding="15,6" Margin="0,0,10,0" BorderThickness="0"/>
                    <Button x:Name="btnSettings" Content="SETTINGS" Click="btnOpenSettings_Click" Background="#333" Foreground="White" Padding="15,6" Margin="0,0,10,0" BorderThickness="0"/>
                    <Button x:Name="btnQueue" Content="QUEUE" Click="btnToggleQueue_Click" Background="#333" Foreground="White" Padding="12,6" Margin="0,0,10,0" BorderThickness="0"/>
                    <Button x:Name="btnLogout" Content="LOGOUT" Click="btnLogout_Click" Background="#D32F2F" Foreground="White" Padding="12,6" Margin="0,0,10,0" BorderThickness="0"/>
                    <ComboBox x:Name="cboGames" Width="170" Height="30" VerticalContentAlignment="Center" SelectionChanged="cboGames_SelectionChanged">
                        <ComboBoxItem Content="Wuthering Waves" Tag="wuthering_waves" IsSelected="True" VerticalContentAlignment="Center"/>
                        <ComboBoxItem Content="Arknights Endfield" Tag="arknights_endfield" VerticalContentAlignment="Center"/>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20,10">
            <TabControl x:Name="tabMain" Background="Transparent" BorderThickness="0" SelectionChanged="tabMain_SelectionChanged">
                <TabItem x:Name="tabStore" Header="STORE"/>
                <TabItem x:Name="tabLibrary" Header="LIBRARY"/>
            </TabControl>
            <ListBox x:Name="lstMods" Background="Transparent" BorderBrush="Transparent" Margin="0,55,0,0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Left"/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#1E1E1E" CornerRadius="12" Margin="10" Width="230" MinHeight="440">
                            <StackPanel>
                                <Border CornerRadius="12,12,0,0" ClipToBounds="True" Height="180" Background="#121212">
                                    <Grid>
                                        <Ellipse x:Name="spinnerRing" Width="30" Height="30" Stroke="#673AB7" StrokeThickness="3" 
                 StrokeDashArray="3,1" RenderTransformOrigin="0.5,0.5"
                 HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Ellipse.RenderTransform>
                                                <RotateTransform Angle="0"/>
                                            </Ellipse.RenderTransform>
                                            <Ellipse.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard Storyboard="{StaticResource SpinAnimation}"/>
                                                </EventTrigger>
                                            </Ellipse.Triggers>
                                        </Ellipse>

                                        <Image Source="{Binding img_url}" Stretch="UniformToFill"/>
                                    </Grid>
                                </Border>
                                <Border Padding="15,12,15,10">
                                    <StackPanel>
                                        <TextBlock Text="{Binding display_name}" Foreground="White" FontSize="17" FontWeight="Bold" TextWrapping="Wrap" HorizontalAlignment="Left" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding version, StringFormat='V{0}'}" Foreground="#673AB7" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Left" Margin="0,0,0,12"/>
                                    </StackPanel>
                                </Border>
                                <StackPanel Margin="15,0,15,15">
                                    <Button Content="{Binding btnText}" Click="btnDownload_Click" Tag="{Binding mod_id}" Style="{StaticResource SmartButtonStyle}" Margin="0,0,0,8"/>
                                    <Button Content="{Binding infoText}" Click="btnOpenPatreon_Click" Tag="{Binding patreon_url}" Background="#2A2A2A" Foreground="#AAA" FontSize="11" Height="30" Margin="0,0,0,8" BorderThickness="0" Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="6"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                    <Button Content="{Binding deleteText}" Click="btnDelete_Click" Tag="{Binding mod_id}" Background="Transparent" Foreground="#FF5252" FontSize="11" Height="25" Visibility="{Binding isInstalled, Converter={StaticResource BoolToVis}}" BorderThickness="0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <Border x:Name="pnlProgress" Grid.Row="1" VerticalAlignment="Bottom" Background="#F21E1E1E" Padding="25,15" Visibility="Collapsed" Panel.ZIndex="1000">
            <StackPanel>
                <Grid>
                    <ProgressBar x:Name="prgDownload" Height="12" Background="#333" Foreground="#673AB7" BorderThickness="0"/>
                    <TextBlock x:Name="lblPercentage" Text="0%" Foreground="White" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                </Grid>
                <Grid Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="lblSpeed" Text="0.00 MB/s" Foreground="#888" FontSize="12" Margin="0,0,20,0"/>
                        <TextBlock x:Name="lblCurrentMod" Text="..." Foreground="#673AB7" FontSize="12" FontWeight="Bold"/>
                    </StackPanel>
                    <Button Content="CANCEL" Click="btnCancelCurrent_Click" HorizontalAlignment="Right" Background="#D32F2F" Foreground="White" FontSize="10" Padding="12,3" BorderThickness="0"/>
                </Grid>
            </StackPanel>
        </Border>

        <Grid x:Name="pnlSettings" Grid.RowSpan="3" Background="#E6000000" Panel.ZIndex="5000" Visibility="Collapsed">
            <Border Background="#1E1E1E" CornerRadius="15" Width="500" VerticalAlignment="Center" HorizontalAlignment="Center" BorderBrush="#333" BorderThickness="1" Padding="30">
                <StackPanel>
                    <TextBlock x:Name="lblSettingsTitle" Text="SETTINGS" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,0,0,25"/>

                    <TextBlock x:Name="lblPathTitle" Text="XXMI ROOT FOLDER" Foreground="#888" FontSize="12" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtPathDisplay" IsReadOnly="False" Background="#121212" Foreground="White" BorderThickness="1" BorderBrush="#333" Padding="10,8"/>
                        <Button x:Name="btnBrowse" Grid.Column="1" Content="BROWSE" Click="btnSelectFolder_Click" Width="80" Margin="5,0,0,0" Background="#333" Foreground="White" BorderThickness="0"/>
                    </Grid>

                    <TextBlock x:Name="lblWwmiPathTitle" Text="CUSTOM WWMI PATH (OPTIONAL)" Foreground="#888" FontSize="12" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtWwmiPath" IsReadOnly="False" Background="#121212" Foreground="White" BorderThickness="1" BorderBrush="#333" Padding="10,8"/>
                        <Button x:Name="btnBrowseWwmi" Grid.Column="1" Content="BROWSE" Click="btnBrowseWwmi_Click" Width="80" Margin="5,0,0,0" Background="#333" Foreground="White" BorderThickness="0"/>
                    </Grid>

                    <TextBlock x:Name="lblEfmiPathTitle" Text="CUSTOM EFMI PATH (OPTIONAL)" Foreground="#888" FontSize="12" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="txtEfmiPath" IsReadOnly="False" Background="#121212" Foreground="White" BorderThickness="1" BorderBrush="#333" Padding="10,8"/>
                        <Button x:Name="btnBrowseEfmi" Grid.Column="1" Content="BROWSE" Click="btnBrowseEfmi_Click" Width="80" Margin="5,0,0,0" Background="#333" Foreground="White" BorderThickness="0"/>
                    </Grid>

                    <TextBlock x:Name="lblLangTitle" Text="LANGUAGE" Foreground="#888" FontSize="12" Margin="0,0,0,8"/>
                    <ComboBox x:Name="cboLang" Margin="0,0,0,30" Height="35" VerticalContentAlignment="Center" SelectionChanged="cboLang_SelectionChanged">
                        <ComboBoxItem Content="English" Tag="en" VerticalContentAlignment="Center"/>
                        <ComboBoxItem Content="Tiếng Việt" Tag="vi" VerticalContentAlignment="Center"/>
                        <ComboBoxItem Content="简体中文" Tag="zh" VerticalContentAlignment="Center"/>
                    </ComboBox>

                    <Button x:Name="btnSaveSettings" Content="CLOSE" Click="btnCloseSettings_Click" Style="{StaticResource SmartButtonStyle}" Height="45" Background="#673AB7"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="pnlLogin" Grid.RowSpan="3" Background="#F2121212" Panel.ZIndex="6000" Visibility="Visible">
            <Border Background="#1E1E1E" CornerRadius="15" Width="380" Height="280" VerticalAlignment="Center" HorizontalAlignment="Center" BorderBrush="#333" BorderThickness="1">
                <StackPanel VerticalAlignment="Center" Margin="20">
                    <TextBlock Text="KAT" Foreground="#673AB7" FontSize="36" FontWeight="ExtraBold" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="lblLoginMember" Text="ACCESS" Foreground="White" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,30"/>
                    <Button x:Name="btnLoginPatreon" Content="LOGIN" Click="btnLoginPatreon_Click" Style="{StaticResource SmartButtonStyle}" Width="280" Height="45" Background="#FF424D"/>
                    <TextBlock x:Name="lblLoginStatus" Text="..." Foreground="#888" Margin="0,20,0,0" HorizontalAlignment="Center" FontSize="12"/>
                    <ProgressBar x:Name="prgLogin" IsIndeterminate="True" Height="4" Width="200" Margin="0,15,0,0" Visibility="Collapsed" Foreground="#673AB7" Background="Transparent" BorderThickness="0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="pnlPathMissing" Grid.RowSpan="3" Background="#E6121212" Panel.ZIndex="4000" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Background="#FFD600" CornerRadius="40" Width="80" Height="80" Margin="0,0,0,20">
                    <TextBlock Text="!" Foreground="Black" FontSize="50" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock x:Name="lblMissTitle" Text="MISSING PATH" Foreground="White" FontSize="28" FontWeight="ExtraBold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="lblMissDesc" Text="Please set XXMI folder." Foreground="#AAA" Margin="0,10,0,30" TextAlignment="Center"/>
                <Button x:Name="btnSelectPath" Content="SELECT FOLDER" Click="btnSelectFolder_Click" Width="300" Height="55" Style="{StaticResource SmartButtonStyle}"/>
            </StackPanel>
        </Grid>

        <Canvas Grid.Row="1" Panel.ZIndex="600" HorizontalAlignment="Right">
            <Border x:Name="brdQueue" Width="300" Background="#1E1E1E" BorderBrush="#333" BorderThickness="1,0,0,1" Visibility="Collapsed" Height="680" Canvas.Right="0">
                <StackPanel Margin="15">
                    <TextBlock x:Name="lblQueueTitle" Text="QUEUE" Foreground="#673AB7" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>
                    <ItemsControl x:Name="itemsQueue">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#252525" Margin="0,0,0,8" Padding="10" CornerRadius="6">
                                    <Grid>
                                        <TextBlock Text="{Binding}" Foreground="White"/>
                                        <Button Content="✕" Click="btnRemoveFromQueue_Click" Tag="{Binding}" HorizontalAlignment="Right" Background="Transparent" Foreground="#FF5252" BorderThickness="0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Canvas>

        <StatusBar Grid.Row="2" Background="#1E1E1E" Foreground="#888">
            <StatusBarItem>
                <TextBlock x:Name="lblStatusMain" Text="Ready"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock x:Name="lblUserInfo" Text="Guest"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>